{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@w6w/types": [
        "../../core/packages/types"
      ]
    }
  },
  "include": [
    "index.ts",
    "actions/**/*.ts",
    "auth/**/*.ts"
  ]
}
